# Godot 4+ specific ignores
.godot/
/android/
*.import

# Godot 3 specific ignores
.import/

# Imported translations (can be safely auto-generated)
*.translation

# Mono/C# specific ignores (if using the .NET version)
.mono/
data_~/
mono_crash.json
*.csproj
*.sln

# Build / Export paths
